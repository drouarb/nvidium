{
  "schemaVersion": 1,
  "id": "nvidium",
  "version": "${version}",
  "custom": {
    "commit": "${commit}",
    "buildtime": "${buildtime}"
  },
  "name": "Nvidium",
  "description": "Replacement rendering engine for Sodium",
  "authors": [
    "Cortex"
  ],
  "contributors": [
    "drouarb"
  ],
  "contact": {
    "homepage": "https://github.com/drouarb/nvidium",
    "issues": "https://github.com/drouarb/nvidium/issues",
    "sources": "https://github.com/MCRcortex/nvidium"
  },
  "license": "LGPL-3.0",
  "icon": "assets/nvidium/nvidium.png",
  "environment": "client",
  "entrypoints": {
    "sodium:config_api_user": [
      "me.cortex.nvidium.config.ConfigGuiBuilder"
    ]
  },
  "accessWidener" : "nvidium.accesswidener",
  "mixins": [
    "nvidium.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": [
      "26.1",
      "26.1.1",
      "26.1.2"
    ],
    "sodium": [
      "0.8.7",
      "0.8.9",
      "0.8.10",
      "0.8.11"
    ]
  }
}
